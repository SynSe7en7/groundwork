# justfile for [[ project_name ]]. Run `just` with no args to list targets.
# uvx means no global Python or Copier install is needed.
# Copier resolves its conditionals and substitutions at scaffold time; just's own
# {{var}} interpolation is left untouched.

default:
    @just --list

# --- Foundation lifecycle ----------------------------------------------------

# Pull the latest foundation release in via Copier's 3-way merge (clean tree).
foundation-update:
    @git diff --quiet || { echo "Commit or stash changes first (clean tree required)."; exit 1; }
    uvx copier update --trust --skip-answered
    @echo "Merged. Resolve any conflict markers or *.rej, then run: just verify"

# Re-prompt every question (for example, to enable a newly added toggle).
foundation-update-interactive:
    @git diff --quiet || { echo "Commit or stash changes first."; exit 1; }
    uvx copier update --trust

# Pin to a specific foundation version instead of the latest tag.
foundation-update-to version:
    uvx copier update --trust --skip-answered --vcs-ref {{version}}

# Forcibly re-baseline from current answers (overwrites template-owned files).
foundation-recopy:
    uvx copier recopy --trust

# Preview the next foundation update as a dry run (writes nothing), before applying.
foundation-update-preview:
    uvx copier update --trust --skip-answered --pretend

# Check prerequisites, a clean tree, and whether this project is behind the latest
# foundation release. Read-only: it reports and suggests the next step.
doctor:
    #!/usr/bin/env bash
    set -uo pipefail
    echo "groundwork doctor"
    for t in uv git just; do
      if command -v "$t" >/dev/null 2>&1; then echo "  $t: ok"; else echo "  $t: MISSING"; fi
    done
    if git diff --quiet 2>/dev/null && git diff --cached --quiet 2>/dev/null; then
      echo "  tree: clean"
    else
      echo "  tree: dirty (commit or stash before foundation-update)"
    fi
    if [ -f .copier-answers.yml ]; then
      cur=$(grep '^_commit:' .copier-answers.yml | head -1 | awk '{print $2}')
      src=$(grep '^_src_path:' .copier-answers.yml | head -1 | awk '{print $2}')
      case "$src" in gh:*) url="https://github.com/${src#gh:}" ;; *) url="$src" ;; esac
      latest=$(git ls-remote --tags --refs "$url" 2>/dev/null | grep -oE 'v[0-9]+\.[0-9]+\.[0-9]+$' | sort -V | tail -1)
      if [ -z "$latest" ]; then echo "  drift: could not reach $url"
      elif [ "$cur" = "$latest" ]; then echo "  drift: up to date ($cur)"
      else echo "  drift: BEHIND (on $cur, latest $latest) -> run: just foundation-update"; fi
    else
      echo "  drift: no .copier-answers.yml (not a tracked instance)"
    fi

# --- Verify (run before every commit and after every update) -----------------

# The app lives in a preset subdirectory (hybrid is a monorepo run from root).
[% if project_type == 'web' %]app_dir := "web"[% endif %]
[% if project_type == 'mobile' %]app_dir := "mobile"[% endif %]
[% if project_type == 'desktop' %]app_dir := "desktop"[% endif %]
[% if project_type == 'hybrid' %]app_dir := "."[% endif %]
[% if project_type == 'core' %]app_dir := "."[% endif %]

verify: lint typecheck test
    @echo "verify: OK"

[% if project_type == 'mobile' %]
lint:
    cd {{app_dir}} && npx expo lint
typecheck:
    cd {{app_dir}} && npx tsc --noEmit
test:
    cd {{app_dir}} && npm test
[% elif project_type == 'hybrid' %]
lint:
    pnpm lint
typecheck:
    pnpm -r typecheck
test:
    pnpm -r test
[% elif project_type == 'core' %]
lint:
    @echo "groundwork core overlay: set lint for this project's stack in the justfile."
typecheck:
    @echo "groundwork core overlay: set typecheck for this project's stack."
test:
    @echo "groundwork core overlay: set test for this project's stack."
[% else %]
lint:
    cd {{app_dir}} && npm run lint
typecheck:
    cd {{app_dir}} && npm run typecheck
test:
    cd {{app_dir}} && npm test
[% endif %]

# --- Health: env self-identification (app_env / version / git_sha) -----------

health env="develop":
    @echo "Checking {{env}} health (set API_BASE_URL to the {{env}} backend first)..."
    @curl -fsS "${API_BASE_URL:?set API_BASE_URL}/api/health" | (command -v jq >/dev/null && jq . || cat)

# --- Deploy: ordered bring-up. Fill in real commands; keep the order. ---------

deploy env="develop":
    @echo "Ordered deploy for {{env}}:"
    @echo "  1) DB migrations first      (e.g. supabase db push)"
    @echo "  2) compute + secret next    (e.g. modal deploy), off the hot path"
    @echo "  3) web env -> live backend URL, then build/deploy LAST"
    @echo "Then run: just health {{env}}"

[% if include_two_env_discipline %]
# Promotion to prod is gated by docs/ENVIRONMENTS.md (must pass E2E twice).
promote:
    @echo "Promotion is gated by docs/ENVIRONMENTS.md (twice-passing E2E). Intentionally manual."
[% endif %]
