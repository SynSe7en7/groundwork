# Placeholders only. Copy to .env (gitignored) and fill real values, or set them
# in the deploy host's secret store. Never commit real values.
# Use the variables your preset reads: web and desktop use NEXT_PUBLIC_*, mobile
# uses EXPO_PUBLIC_*, hybrid uses both. Delete the lines you do not need.

# Which environment this process is. Drives /api/health and the UI env badge.
APP_ENV=develop

# Supabase (new key format; legacy anon/service_role JWTs deprecate end of 2026).
# Publishable keys are client-safe; the secret key is server-only and bypasses RLS.

# Web / desktop (Next.js):
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx

# Mobile (Expo):
EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
EXPO_PUBLIC_APP_ENV=develop

# Server-only (never in a client bundle or a NEXT_PUBLIC_/EXPO_PUBLIC_ var):
SUPABASE_SECRET_KEY=sb_secret_xxx

# Modal escape hatch (only if enabled). The app or an Edge Function calls this
# over HTTPS; the token is shared so callbacks can be verified.
MODAL_ENDPOINT_URL=https://<workspace>--<app>.modal.run
MODAL_TOKEN=__set_me__
# Separate shared secret the web jobs callback route verifies on inbound calls.
# Must differ from MODAL_TOKEN.
MODAL_CALLBACK_TOKEN=__set_me__
