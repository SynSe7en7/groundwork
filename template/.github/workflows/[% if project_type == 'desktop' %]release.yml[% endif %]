name: release-desktop

# Cut a release by pushing a tag like v0.1.0. tauri-action builds each OS,
# signs the bundles + updater artifacts, and attaches them (plus latest.json)
# to the GitHub Release the updater endpoint reads.
on:
  push:
    tags:
      - "v*"

jobs:
  build:
    permissions:
      contents: write       # create the release, upload assets, read source
      id-token: write       # mint the OIDC token the provenance attestation signs with
      attestations: write   # store the signed build-provenance attestation
    strategy:
      fail-fast: false
      matrix:
        include:
          - platform: macos-latest
            args: "--target aarch64-apple-darwin"
          - platform: macos-latest
            args: "--target x86_64-apple-darwin"
          - platform: ubuntu-22.04
            args: ""
          - platform: windows-latest
            args: ""

    runs-on: ${{ matrix.platform }}
    steps:
      - uses: actions/checkout@34e114876b0b11c390a56381ad16ebd13914f8d5 # v4

      - name: Install Linux webview + build deps
        if: matrix.platform == 'ubuntu-22.04'
        run: |
          sudo apt-get update
          sudo apt-get install -y \
            libwebkit2gtk-4.1-dev \
            libappindicator3-dev \
            librsvg2-dev \
            patchelf \
            build-essential \
            curl wget file libssl-dev libxdo-dev libgtk-3-dev

      - name: Setup Node
        uses: actions/setup-node@49933ea5288caeca8642d1e84afbd3f7d6820020 # v4
        with:
          node-version: 20

      - name: Setup Rust
        uses: dtolnay/rust-toolchain@29eef336d9b2848a0b548edc03f92a220660cdb8 # stable
        with:
          toolchain: stable
          targets: ${{ matrix.platform == 'macos-latest' && 'aarch64-apple-darwin,x86_64-apple-darwin' || '' }}

      - name: Cache cargo
        uses: swatinem/rust-cache@e18b497796c12c097a38f9edb9d0641fb99eee32 # v2
        with:
          workspaces: "./desktop/src-tauri -> target"

      - name: Install frontend dependencies
        working-directory: desktop
        run: npm install

      - name: Build, sign, and release
        id: tauri
        uses: tauri-apps/tauri-action@84b9d35b5fc46c1e45415bdb6144030364f7ebc5 # v0
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
          # Updater signing keypair (required so the updater can verify updates).
          TAURI_SIGNING_PRIVATE_KEY: ${{ secrets.TAURI_SIGNING_PRIVATE_KEY }}
          TAURI_SIGNING_PRIVATE_KEY_PASSWORD: ${{ secrets.TAURI_SIGNING_PRIVATE_KEY_PASSWORD }}
          # macOS notarization + code signing (only used on the macOS matrix legs).
          APPLE_CERTIFICATE: ${{ secrets.APPLE_CERTIFICATE }}
          APPLE_CERTIFICATE_PASSWORD: ${{ secrets.APPLE_CERTIFICATE_PASSWORD }}
          APPLE_SIGNING_IDENTITY: ${{ secrets.APPLE_SIGNING_IDENTITY }}
          APPLE_ID: ${{ secrets.APPLE_ID }}
          APPLE_PASSWORD: ${{ secrets.APPLE_PASSWORD }}
          APPLE_TEAM_ID: ${{ secrets.APPLE_TEAM_ID }}
        with:
          projectPath: desktop
          tagName: ${{ github.ref_name }}
          releaseName: ${{ github.ref_name }}
          releaseBody: "See the assets to download and install this version."
          releaseDraft: true
          prerelease: false
          includeUpdaterJson: true
          args: ${{ matrix.args }}

      # Supply-chain provenance + SBOM (SLSA Build L2+). tauri-action signs the
      # bundles; these steps prove WHERE they were built and WHAT went into them.
      # This workflow only runs on a real v*-tagged release, so it cannot be
      # exercised by the foundation's render/PR CI; it is verified on a real
      # desktop project's release.
      - name: Collect built artifact paths
        id: artifacts
        shell: bash
        run: |
          set -euo pipefail
          # tauri-action reports the signed bundles as a JSON array of paths.
          paths=$(printf '%s' '${{ steps.tauri.outputs.artifactPaths }}' | jq -r '.[]')
          if [ -z "$paths" ]; then
            echo "tauri-action reported no artifact paths to attest" >&2
            exit 1
          fi
          {
            echo 'paths<<EOF'
            printf '%s\n' "$paths"
            echo 'EOF'
          } >> "$GITHUB_OUTPUT"

      - name: Attest build provenance
        uses: actions/attest-build-provenance@0f67c3f4856b2e3261c31976d6725780e5e4c373 # v4.1.1
        with:
          # One attestation per matrix leg, covering the binaries that leg built.
          # Verify after release with: gh attestation verify <file> --repo <owner>/<repo>
          subject-path: ${{ steps.artifacts.outputs.paths }}

      # One canonical SBOM: the npm + cargo dependency graph is platform-independent,
      # so generate it once (on Linux) rather than four near-identical copies.
      - name: Generate SBOM (syft)
        if: matrix.platform == 'ubuntu-22.04'
        uses: anchore/sbom-action@e22c389904149dbc22b58101806040fa8d37a610 # v0.24.0
        with:
          path: desktop
          format: spdx-json
          output-file: sbom.spdx.json
          artifact-name: sbom.spdx.json
          upload-release-assets: false

      - name: Attach SBOM to the release
        if: matrix.platform == 'ubuntu-22.04'
        shell: bash
        env:
          GH_TOKEN: ${{ secrets.GITHUB_TOKEN }}
        run: gh release upload "${{ github.ref_name }}" sbom.spdx.json --clobber --repo "${{ github.repository }}"
