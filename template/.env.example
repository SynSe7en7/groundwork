# Placeholders only. Copy to .env (gitignored) and fill with real values, or set
# these in the deploy host's secret store. Never commit real values.

# Which environment this process is. Drives /api/health and the UI env badge.
APP_ENV=develop

# Supabase (new key format; legacy anon/service_role JWTs deprecate end of 2026).
# Publishable key is safe in client bundles. Secret key is server-only; it
# bypasses RLS and must never reach a client or a NEXT_PUBLIC_/EXPO_PUBLIC_ var.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SECRET_KEY=sb_secret_xxx

# Modal escape hatch (only if used). The app calls this over HTTPS; the secret
# is shared with Modal so callbacks can be verified.
MODAL_JOBS_ENDPOINT=https://<workspace>--<app>.modal.run
MODAL_WEBHOOK_SECRET=__set_me__
