name: ci

on:
  push:
    branches: [main, develop]
  pull_request:

permissions:
  contents: read
  pull-requests: write

concurrency:
  group: ci-${{ github.ref }}
  cancel-in-progress: true

jobs:
[% if project_type != 'core' %]
  # Hard gate: the app must install, typecheck, lint, and build. This scaffold
  # keeps its package manifest and lockfile under its own app directory, so the
  # job runs there (a root-level npm install would find no lockfile).
  build:
    name: typecheck / lint / build
    runs-on: ubuntu-latest
[% if project_type == 'hybrid' %]
    steps:
      - uses: actions/checkout@34e114876b0b11c390a56381ad16ebd13914f8d5 # v4
      - uses: actions/setup-node@49933ea5288caeca8642d1e84afbd3f7d6820020 # v4
        with:
          node-version: 20
      - run: corepack enable
      - name: Install, type-check, and lint + build the web app
        run: |
          pnpm install --frozen-lockfile
          pnpm -r run type-check
          pnpm --filter web run lint
          pnpm --filter web run build
[% else %]
    defaults:
      run:
        working-directory: [[ project_type ]]
    steps:
      - uses: actions/checkout@34e114876b0b11c390a56381ad16ebd13914f8d5 # v4
      - uses: actions/setup-node@49933ea5288caeca8642d1e84afbd3f7d6820020 # v4
        with:
          node-version: 20
          cache: npm
          cache-dependency-path: [[ project_type ]]/package-lock.json
      - name: Install
        run: npm ci
      - name: Typecheck
        run: npm run typecheck --if-present
[% if project_type != 'mobile' %]
      - name: Lint
        run: npm run lint --if-present
      - name: Build
        run: npm run build --if-present
[% endif %]
[% endif %]
[% endif %]

  # Enforced alignment gates (was the advisory tripwires). Maps the PR diff to the
  # gates it triggers (Stack via dependency manifests, Design via a new UI surface,
  # Deployment & Security via migrations, env, or deploy/security docs) and fails
  # when a triggered gate is not ratified in docs/GATES.md, unless its artifact is
  # updated in this PR or the PR body carries 'gate-exempt: <key>'. The decision to
  # enforce is recorded in the foundation's docs/adr/0001-enforce-alignment-gates.md.
  alignment-gates:
    name: alignment gates enforced
    runs-on: ubuntu-latest
    if: github.event_name == 'pull_request'
    steps:
      - uses: actions/checkout@34e114876b0b11c390a56381ad16ebd13914f8d5 # v4
        with:
          fetch-depth: 0
      - name: Enforce alignment gates on the PR diff
        env:
          BASE_REF: ${{ github.base_ref }}
          BASE_SHA: ${{ github.event.pull_request.base.sha }}
          PR_BODY: ${{ github.event.pull_request.body }}
        run: bash scripts/check-gates.sh

  # Hard gate: a committed secret fails the PR. Pinned gitleaks binary, no license
  # needed (works in private repos too).
  secret-scan:
    name: secret scan (gitleaks)
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@34e114876b0b11c390a56381ad16ebd13914f8d5 # v4
      - name: Run gitleaks
        run: |
          set -euo pipefail
          VERSION=8.30.1
          curl -sSL "https://github.com/gitleaks/gitleaks/releases/download/v${VERSION}/gitleaks_${VERSION}_linux_x64.tar.gz" \
            | tar -xz gitleaks
          ./gitleaks dir . --redact --no-banner
